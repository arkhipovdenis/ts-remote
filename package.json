{
  "name": "ts-remote",
  "version": "2.0.0",
  "description": "TypeScript declaration builder for sharing types between independent modules",
  "keywords": [
    "typescript",
    "dts",
    "declarations",
    "builder",
    "microfrontend",
    "types",
    "type-sharing",
    "remote-types",
    "language-service-plugin"
  ],
  "bin": {
    "ts-remote": "./cli/index.js"
  },
  "scripts": {
    "prettier:fix": "prettier ./packages/**/*.ts -l --write",
    "prettier:check": "prettier ./packages/**/*.ts -l --check",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run typecheck",
    "build": "ts-node --transpileOnly ./scripts/build.ts",
    "test:compile": "ts-node --transpileOnly packages/builder/__test__/builder.test.ts",
    "test:cli": "ts-node --transpileOnly packages/cli/__test__/parse-args.test.ts && ts-node --transpileOnly packages/cli/__test__/fetch-command.test.ts",
    "test:fetcher": "ts-node --transpileOnly packages/fetcher/__test__/config.test.ts && ts-node --transpileOnly packages/fetcher/__test__/cache.test.ts && ts-node --transpileOnly packages/fetcher/__test__/http.test.ts && ts-node --transpileOnly packages/fetcher/__test__/fetch.test.ts",
    "test:plugin": "ts-node --transpileOnly packages/plugin/__test__/plugin.test.ts",
    "test": "npm run test:cli && npm run test:fetcher && npm run test:plugin"
  },
  "exports": {
    "./builder": {
      "types": "./builder/index.d.ts",
      "require": "./builder/index.js",
      "default": "./builder/index.js"
    },
    "./fetcher": {
      "types": "./fetcher/index.d.ts",
      "require": "./fetcher/index.js",
      "default": "./fetcher/index.js"
    },
    "./plugin": {
      "types": "./plugin/index.d.ts",
      "require": "./plugin/index.js",
      "default": "./plugin/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkhipovdenis/ts-remote.git"
  },
  "author": "Denis Arkhipov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arkhipovdenis/ts-remote.git/issues"
  },
  "homepage": "https://github.com/arkhipovdenis/ts-remote.git#readme",
  "peerDependencies": {
    "typescript": ">=4.9"
  },
  "devDependencies": {
    "@types/node": "^20.1.0",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
}
